generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum MovementType {
  RECEIPT
  DELIVERY
  TRANSFER
  ADJUSTMENT
}

enum DocumentStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELED
}

// ──────────────────────────────────────────
// Users
// ──────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now()) @map("created_at")

  receipts   Receipt[]
  deliveries Delivery[]

  @@map("users")
}

// ──────────────────────────────────────────
// Warehouses & Locations
// ──────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")

  locations  Location[]
  receipts   Receipt[]
  deliveries Delivery[]

  @@map("warehouses")
}

model Location {
  id          String @id @default(uuid())
  warehouseId String @map("warehouse_id")
  name        String
  type        String

  warehouse          Warehouse       @relation(fields: [warehouseId], references: [id])
  stockMovementsFrom StockMovement[] @relation("FromLocation")
  stockMovementsTo   StockMovement[] @relation("ToLocation")
  transfersFrom      Transfer[]      @relation("TransferFrom")
  transfersTo        Transfer[]      @relation("TransferTo")
  adjustments        Adjustment[]
  receipts           Receipt[]
  deliveries         Delivery[]      @relation("DeliveryLocation")

  @@map("locations")
}

// ──────────────────────────────────────────
// Products & Categories
// ──────────────────────────────────────────

model Category {
  id   String @id @default(uuid())
  name String @unique

  products Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  sku           String   @unique
  categoryId    String   @map("category_id")
  unitOfMeasure String   @map("unit_of_measure")
  unitCost      Float?   @default(0) @map("unit_cost")
  createdAt     DateTime @default(now()) @map("created_at")

  category       Category       @relation(fields: [categoryId], references: [id])
  stockMovements StockMovement[]
  receiptItems   ReceiptItem[]
  deliveryItems  DeliveryItem[]
  transferItems  TransferItem[]
  adjustments    Adjustment[]

  @@map("products")
}

// ──────────────────────────────────────────
// Stock Movement Ledger
// ──────────────────────────────────────────

model StockMovement {
  id             String       @id @default(uuid())
  productId      String       @map("product_id")
  fromLocationId String?      @map("from_location_id")
  toLocationId   String?      @map("to_location_id")
  quantity       Int
  movementType   MovementType @map("movement_type")
  referenceId    String       @map("reference_id")
  referenceType  String       @map("reference_type")
  createdAt      DateTime     @default(now()) @map("created_at")

  product      Product   @relation(fields: [productId], references: [id])
  fromLocation Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])

  @@index([productId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([movementType])
  @@map("stock_movements")
}

// ──────────────────────────────────────────
// Receipts (Incoming Goods)
// ──────────────────────────────────────────

model Receipt {
  id           String         @id @default(uuid())
  referenceId  String         @unique @map("reference_id")
  contact      String?        @map("contact")
  supplierName String         @map("supplier_name") // Keeping this for backward compatibility or linking
  warehouseId  String         @map("warehouse_id")
  toLocationId String?        @map("to_location_id")
  scheduleDate DateTime?      @map("schedule_date")
  status       DocumentStatus @default(DRAFT)
  createdBy    String         @map("created_by")
  createdAt    DateTime       @default(now()) @map("created_at")

  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  location  Location?     @relation(fields: [toLocationId], references: [id])
  creator   User          @relation(fields: [createdBy], references: [id])
  items     ReceiptItem[]

  @@map("receipts")
}

model ReceiptItem {
  id        String @id @default(uuid())
  receiptId String @map("receipt_id")
  productId String @map("product_id")
  quantity  Int

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("receipt_items")
}

// ──────────────────────────────────────────
// Deliveries (Outgoing Goods)
// ──────────────────────────────────────────

model Delivery {
  id             String         @id @default(uuid())
  referenceId    String         @unique @map("reference_id")
  contact        String?        @map("contact")
  customerName   String         @map("customer_name")
  warehouseId    String         @map("warehouse_id")
  fromLocationId String?        @map("from_location_id")
  scheduleDate   DateTime?      @map("schedule_date")
  status         DocumentStatus @default(DRAFT)
  createdBy      String         @map("created_by")
  createdAt      DateTime       @default(now()) @map("created_at")

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  location  Location?      @relation("DeliveryLocation", fields: [fromLocationId], references: [id])
  creator   User           @relation(fields: [createdBy], references: [id])
  items     DeliveryItem[]

  @@map("deliveries")
}

model DeliveryItem {
  id         String @id @default(uuid())
  deliveryId String @map("delivery_id")
  productId  String @map("product_id")
  quantity   Int

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("delivery_items")
}

// ──────────────────────────────────────────
// Transfers
// ──────────────────────────────────────────

model Transfer {
  id             String         @id @default(uuid())
  fromLocationId String         @map("from_location_id")
  toLocationId   String         @map("to_location_id")
  status         DocumentStatus @default(DRAFT)
  createdAt      DateTime       @default(now()) @map("created_at")

  fromLocation Location       @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation   Location       @relation("TransferTo", fields: [toLocationId], references: [id])
  items        TransferItem[]

  @@map("transfers")
}

model TransferItem {
  id         String @id @default(uuid())
  transferId String @map("transfer_id")
  productId  String @map("product_id")
  quantity   Int

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("transfer_items")
}

// ──────────────────────────────────────────
// Adjustments
// ──────────────────────────────────────────

model Adjustment {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  locationId     String   @map("location_id")
  quantityChange Int      @map("quantity_change")
  reason         String
  createdAt      DateTime @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("adjustments")
}
